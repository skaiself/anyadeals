---
interface Props {
  icon: string;
  title: string;
  subtitle: string;
}
const { icon, title, subtitle } = Astro.props;
---
<div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white border border-border-raw/10">
  <span class="text-2xl" aria-hidden="true">{icon}</span>
  <div>
    <p class="text-sm font-semibold text-ink">{title}</p>
    <p class="text-xs text-ink-muted">{subtitle}</p>
  </div>
</div>
