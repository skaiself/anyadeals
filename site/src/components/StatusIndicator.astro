---
interface Props {
  status: 'success' | 'failure' | 'unknown';
  label: string;
  lastRun: string;
  nextRun: string;
  lastError?: string | null;
}
const { status, label, lastRun, nextRun, lastError } = Astro.props;

const statusColors = {
  success: 'bg-green-500',
  failure: 'bg-red-500',
  unknown: 'bg-yellow-500',
};

const formatTime = (iso: string) => new Date(iso).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', timeZoneName: 'short'
});
---
<div class="rounded-lg border border-border-raw/10 bg-white p-5">
  <div class="flex items-center gap-2 mb-3">
    <span class:list={['w-3 h-3 rounded-full', statusColors[status]]}></span>
    <h3 class="font-semibold text-ink capitalize">{label}</h3>
  </div>
  <div class="space-y-1 text-xs text-ink-muted">
    <p>Last run: {formatTime(lastRun)}</p>
    <p>Next run: {formatTime(nextRun)}</p>
    {lastError && <p class="text-red-600">Error: {lastError}</p>}
  </div>
</div>
