---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Coupons', href: '/coupons/iherb' },
  { label: 'About', href: '/about' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-cream/80 border-b border-[color:var(--color-border-raw)]/10">
  <div class="max-w-5xl mx-auto px-8 h-16 flex items-center justify-between">

    <!-- Brand -->
    <a href="/" class="font-brand text-xl tracking-wide text-ink hover:opacity-70 transition-opacity shrink-0">
      AnyaDeals
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={[
            'text-sm font-medium transition-colors duration-200',
            isActive(link.href)
              ? 'text-ink border-b border-ink pb-0.5'
              : 'text-ink-muted hover:text-ink',
          ].join(' ')}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile: hamburger (CSS checkbox trick, no JS) -->
    <div class="md:hidden flex items-center">
      <input
        type="checkbox"
        id="nav-toggle"
        class="peer sr-only"
        aria-label="Toggle navigation menu"
      />
      <label
        for="nav-toggle"
        class="cursor-pointer flex flex-col gap-1.5 p-2 -mr-2 select-none"
        aria-hidden="true"
      >
        <!-- Three lines that morph to X via peer-checked sibling styling -->
        <span class="hamburger-line peer-checked:rotate-45 peer-checked:translate-y-2.5"></span>
        <span class="hamburger-line peer-checked:opacity-0"></span>
        <span class="hamburger-line peer-checked:-rotate-45 peer-checked:-translate-y-2.5"></span>
      </label>

      <!-- Mobile dropdown — shown when checkbox is checked -->
      <nav
        class="mobile-nav peer-checked:flex"
        aria-label="Mobile navigation"
      >
        {navLinks.map(link => (
          <a
            href={link.href}
            class={[
              'text-base font-medium py-3 border-b border-ink/10 transition-colors duration-200',
              isActive(link.href) ? 'text-ink' : 'text-ink-muted hover:text-ink',
            ].join(' ')}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

  </div>
</header>

<style>
  /* Hamburger lines */
  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-ink);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  /* The checkbox is hidden; we use the peer-checked state on the label's
     sibling .mobile-nav via the general sibling combinator */
  #nav-toggle:checked ~ .md\:hidden .mobile-nav,
  /* Fallback: target via the label's parent flex container */
  #nav-toggle:checked + label + .mobile-nav {
    display: flex;
  }

  /* We position .mobile-nav absolutely so it overlays below the header */
  .mobile-nav {
    display: none;
    flex-direction: column;
    position: absolute;
    top: 4rem; /* 64px = h-16 */
    left: 0;
    right: 0;
    background: color-mix(in srgb, var(--color-cream) 95%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.5rem 2rem 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border-raw) 10%, transparent);
    z-index: 40;
  }

  /* Hamburger morph when checked — we rely on label containing the spans
     and peer class on the checkbox label relationship */
  #nav-toggle:checked + label span:nth-child(1) {
    transform: rotate(45deg) translate(3px, 5px);
  }
  #nav-toggle:checked + label span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-toggle:checked + label span:nth-child(3) {
    transform: rotate(-45deg) translate(3px, -5px);
  }
</style>

<script>
  // Close menu when a nav link is clicked (SPA-style navigation)
  document.querySelectorAll('.mobile-nav a').forEach(link => {
    link.addEventListener('click', () => {
      const toggle = document.getElementById('nav-toggle') as HTMLInputElement | null;
      if (toggle) toggle.checked = false;
    });
  });
</script>
