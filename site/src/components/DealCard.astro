---
interface Props {
  title: string;
  excerpt: string;
  category: 'wellness' | 'tech' | 'deals';
  href: string;
  featured?: boolean;
  readTime?: string;
}

const { title, excerpt, category, href, featured = false, readTime } = Astro.props;

const categoryColors = {
  wellness: 'bg-signal text-cream',
  tech: 'bg-ink text-cream',
  deals: 'bg-gold text-cream',
};
---
<a href={href} class:list={[
  'block rounded-lg border border-border-raw/10 p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-1 bg-white',
  featured && 'md:col-span-2 md:flex md:gap-8'
]}>
  <div>
    <span class:list={['inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-3', categoryColors[category]]}>
      {category}
    </span>
    <h3 class="font-serif text-xl font-bold leading-snug text-ink">{title}</h3>
    <p class="text-ink-muted mt-2 text-sm leading-relaxed">{excerpt}</p>
    {readTime && <span class="text-xs text-ink-muted/60 mt-3 block">{readTime}</span>}
  </div>
</a>
