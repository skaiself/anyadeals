---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Coupons', href: '/coupons/iherb' },
  { label: 'About', href: '/about' },
  { label: 'Affiliate Disclosure', href: '/about#disclosure' },
];
---

<footer class="bg-ink text-cream py-16 px-8">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">

      <!-- Brand block -->
      <div class="flex flex-col gap-3">
        <a href="/" class="font-brand text-2xl tracking-wide text-cream hover:opacity-80 transition-opacity">
          AnyaDeals
        </a>
        <p class="text-cream/60 text-sm max-w-xs leading-relaxed">
          Curated finds for life, tech &amp; wellness.
        </p>
      </div>

      <!-- Nav links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-col gap-3">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-cream/60 hover:text-cream text-sm transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Divider + copyright -->
    <div class="mt-12 pt-8 border-t border-cream/10">
      <p class="text-cream/40 text-xs">
        &copy; 2026 AnyaDeals. All rights reserved.
      </p>
    </div>
  </div>
</footer>
