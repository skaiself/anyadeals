---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CouponCard from '../../components/CouponCard.astro';
import CouponTicket from '../../components/CouponTicket.tsx';
import TrustBadge from '../../components/TrustBadge.astro';
import RevealOnScroll from '../../components/RevealOnScroll.astro';

import couponsData from '../../data/coupons.json';

const activeCoupons = couponsData.filter(c => c.status === 'valid' || c.status === 'region_limited');
const expiredCoupons = couponsData.filter(c => c.status === 'expired');
---

<BaseLayout title="How to Stack iHerb Discounts — AnyaDeals">
  <div class="max-w-4xl mx-auto px-6 py-16">

    <!-- Breadcrumb -->
    <nav class="text-sm text-ink-muted mb-8">
      <a href="/" class="hover:text-signal">Home</a>
      <span class="mx-2">/</span>
      <a href="/coupons/iherb" class="hover:text-signal">Coupons</a>
      <span class="mx-2">/</span>
      <span class="text-ink">iHerb</span>
    </nav>

    <!-- Page Header -->
    <RevealOnScroll>
      <p class="text-xs uppercase tracking-widest text-signal font-semibold mb-3">Wellness · Savings Guide</p>
      <h1 class="headline-lg mb-6">How to Stack iHerb Discounts</h1>
      <p class="border-l-4 border-signal pl-6 text-ink-muted leading-relaxed">
        Layer a Rewards Code with an official promo code at checkout to unlock the deepest possible discount. Every code below has been automatically verified.
      </p>
    </RevealOnScroll>

    <!-- Trust Badges -->
    <RevealOnScroll class="mt-16" delay={100}>
      <div class="flex flex-wrap gap-4">
        <TrustBadge icon="⭐" title="Verified by Anya" subtitle="Personally tested checkout flow" />
        <TrustBadge icon="⏱️" title="Updated Today" subtitle="Codes checked automatically" />
        <TrustBadge icon="🌍" title="EU & Balkan Shipping" subtitle="Ships to RS, HR, SI, MK, BA +" />
      </div>
    </RevealOnScroll>

    <!-- Automated Coupon Feed -->
    <RevealOnScroll class="mt-16">
      <h2 class="headline-md mb-8">Verified Promo Codes</h2>

      <div class="flex flex-col gap-4">
        {activeCoupons.map((coupon) => (
          <CouponCard
            code={coupon.code}
            discount={coupon.discount}
            type={coupon.type}
            status={coupon.status as 'valid' | 'expired' | 'region_limited' | 'invalid' | 'discovered'}
            regions={coupon.regions}
            lastValidated={coupon.last_validated}
            stackableWithReferral={coupon.stackable_with_referral}
            notes={coupon.notes}
            source={coupon.source}
            minCartValue={coupon.min_cart_value}
          />
        ))}
      </div>

      {expiredCoupons.length > 0 && (
        <details class="mt-6 border border-border-raw/10 rounded-lg">
          <summary class="px-6 py-4 cursor-pointer text-sm font-semibold text-ink-muted hover:text-ink transition-colors select-none">
            Expired Codes ({expiredCoupons.length})
          </summary>
          <div class="px-6 pb-6 flex flex-col gap-4 mt-2">
            {expiredCoupons.map((coupon) => (
              <CouponCard
                code={coupon.code}
                discount={coupon.discount}
                type={coupon.type}
                status={coupon.status as 'valid' | 'expired' | 'region_limited' | 'invalid' | 'discovered'}
                regions={coupon.regions}
                lastValidated={coupon.last_validated}
                stackableWithReferral={coupon.stackable_with_referral}
                notes={coupon.notes}
                source={coupon.source}
                minCartValue={coupon.min_cart_value}
              />
            ))}
          </div>
        </details>
      )}
    </RevealOnScroll>

    <!-- Stacking Guide -->
    <RevealOnScroll class="mt-16">
      <h2 class="headline-md mb-8">How to Stack for Maximum Savings</h2>

      <div class="flex flex-col gap-10">

        <!-- Step 1 -->
        <div>
          <p class="text-xs uppercase tracking-widest text-signal font-semibold mb-2">Step 1</p>
          <h3 class="text-lg font-semibold text-ink mb-3">Enter Your Rewards Code</h3>
          <p class="text-ink-muted mb-5">
            Use code OFR0296 in the Loyalty Programs section for an extra 5% back on every order.
          </p>
          <CouponTicket client:visible code="OFR0296" label="REWARDS CODE" sublabel="5% loyalty discount on every order" />
        </div>

        <!-- Step 2 -->
        <div>
          <p class="text-xs uppercase tracking-widest text-signal font-semibold mb-2">Step 2</p>
          <h3 class="text-lg font-semibold text-ink mb-3">Apply a Promo Code</h3>
          <p class="text-ink-muted">
            At checkout, enter one of the verified promo codes above. iHerb will automatically apply the best available discount.
          </p>
        </div>

        <!-- Step 3 -->
        <div>
          <p class="text-xs uppercase tracking-widest text-signal font-semibold mb-2">Step 3</p>
          <h3 class="text-lg font-semibold text-ink mb-3">See Your Real Savings</h3>
          <p class="text-ink-muted mb-6">
            Stack both codes and see exactly how much you save on the supplements you already buy. Here's a real breakdown:
          </p>

          <!-- Comparison Table -->
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="text-left border-b-2 border-ink">
                <tr>
                  <th class="py-3 font-semibold">Product</th>
                  <th class="py-3 font-semibold">Servings</th>
                  <th class="py-3 font-semibold">Retail</th>
                  <th class="py-3 font-semibold">With Codes</th>
                  <th class="py-3 font-semibold text-signal">You Save</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border-raw/10">
                <tr>
                  <td class="py-3">
                    <p class="font-semibold">Magnesium Glycinate</p>
                    <p class="text-xs text-ink-muted">Doctor's Best, 240ct</p>
                  </td>
                  <td class="py-3">120</td>
                  <td class="py-3">$40.99 <span class="text-xs text-ink-muted">($0.34/srv)</span></td>
                  <td class="py-3 font-semibold">$32.79 <span class="text-xs text-ink-muted">($0.27/srv)</span></td>
                  <td class="py-3 text-signal font-bold">20%</td>
                </tr>
                <tr>
                  <td class="py-3">
                    <p class="font-semibold">Creatine Monohydrate</p>
                    <p class="text-xs text-ink-muted">Optimum Nutrition, 1.32kg</p>
                  </td>
                  <td class="py-3">264</td>
                  <td class="py-3">$29.99 <span class="text-xs text-ink-muted">($0.11/srv)</span></td>
                  <td class="py-3 font-semibold">$22.99 <span class="text-xs text-ink-muted">($0.087/srv)</span></td>
                  <td class="py-3 text-signal font-bold">23%</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </RevealOnScroll>

    <!-- CTA Section -->
    <RevealOnScroll class="mt-16">
      <div class="text-center">
        <a
          href="https://www.iherb.com/?rcode=OFR0296"
          target="_blank"
          rel="noopener"
          class="inline-block bg-signal text-cream px-12 py-5 rounded-lg text-lg font-semibold hover:bg-signal/90 transition-colors"
        >
          Shop iHerb Now
        </a>
        <p class="mt-4 text-sm text-ink-muted">Free shipping on orders over $30. Ships to 180+ countries.</p>
      </div>
    </RevealOnScroll>

  </div>
</BaseLayout>
