---
import BaseLayout from '../layouts/BaseLayout.astro';
import DealCard from '../components/DealCard.astro';
import RevealOnScroll from '../components/RevealOnScroll.astro';
import coupons from '../data/coupons.json';

const validCoupons = coupons.filter((c) => c.status === 'valid');
const couponCount = validCoupons.length;

const picks = [
  {
    id: 'iherb-coupon-stack',
    category: 'wellness' as const,
    title: 'How to stack iHerb codes for maximum savings.',
    excerpt: 'Layer a Rewards Code with official promos for the deepest discount on supplements shipped worldwide.',
    href: '/coupons/iherb',
    featured: true,
    readTime: '4 min read',
  },
  {
    id: 'tech-picks',
    category: 'tech' as const,
    title: 'The 5 tech buys worth every cent this month.',
    excerpt: "From budget earbuds to a home office monitor that won't break your back or your bank.",
    href: '/deals/tech',
    featured: false,
    readTime: '6 min read',
  },
  {
    id: 'morning-rituals',
    category: 'wellness' as const,
    title: 'Morning rituals that actually move the needle.',
    excerpt: 'Science-backed routines from sleep scheduling to cold exposure. No gimmicks.',
    href: '/deals/wellness',
    featured: false,
    readTime: '5 min read',
  },
  {
    id: 'deals-roundup',
    category: 'deals' as const,
    title: "This week's silent deals: trending below the fold.",
    excerpt: 'Flash sales, loyalty cashback stacks, and quiet product drops our readers keep requesting.',
    href: '/deals/deals',
    featured: false,
    readTime: '3 min read',
  },
];
---

<BaseLayout title="AnyaDeals — Curated Finds for Life, Tech & Wellness">

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-24 md:py-32">
    <!-- Decorative background text -->
    <span
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 flex items-center justify-center text-[20vw] font-black uppercase leading-none select-none text-ink opacity-[0.05]"
    >
      DEALS
    </span>

    <div class="relative max-w-6xl mx-auto px-6">
      <RevealOnScroll delay={0}>
        <p class="text-xs uppercase tracking-widest text-ink-muted font-semibold mb-4">
          Curated Deals · March 2026
        </p>
      </RevealOnScroll>

      <RevealOnScroll delay={100}>
        <h1 class="headline-xl mb-6">
          Curated finds for life, tech &amp; wellness.
        </h1>
      </RevealOnScroll>

      <RevealOnScroll delay={200}>
        <p class="text-ink-muted text-lg leading-relaxed max-w-2xl mb-10">
          Cut through the noise. Every deal, code, and product verified — saving you hours and real money.
        </p>
      </RevealOnScroll>

      <RevealOnScroll delay={300}>
        <div class="flex flex-wrap gap-4">
          <a
            href="/coupons/iherb"
            class="bg-signal text-cream rounded px-8 py-4 font-semibold text-sm tracking-wide hover:opacity-90 transition-opacity"
          >
            Stack iHerb Codes
          </a>
          <a
            href="#deals"
            class="border border-ink text-ink rounded px-8 py-4 font-semibold text-sm tracking-wide hover:bg-ink hover:text-cream transition-colors"
          >
            Browse All Deals
          </a>
        </div>
      </RevealOnScroll>
    </div>
  </section>

  <!-- Active Coupons Banner -->
  <div class="max-w-6xl mx-auto px-6 mb-12">
    <a
      href="/coupons/iherb"
      class="block bg-signal/5 border border-signal/20 rounded-lg p-4 text-center text-sm text-ink hover:bg-signal/10 transition-colors"
    >
      <span class="font-semibold text-signal">{couponCount} verified iHerb codes active</span>
      {' '}— Stack them now →
    </a>
  </div>

  <!-- Deal Feed Section -->
  <section id="deals" class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <RevealOnScroll delay={0}>
        <h2 class="headline-lg mb-10">Trending Picks</h2>
      </RevealOnScroll>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {picks.map((card, i) => (
          <RevealOnScroll delay={i * 80} class={card.featured ? 'md:col-span-2' : ''}>
            <DealCard
              title={card.title}
              excerpt={card.excerpt}
              category={card.category}
              href={card.href}
              featured={card.featured}
              readTime={card.readTime}
            />
          </RevealOnScroll>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
