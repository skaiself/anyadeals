# GitHub (orchestrator — for git push to trigger Cloudflare deploy)
GITHUB_TOKEN=ghp_xxxx

# IPRoyal Web Unblocker proxy (validator — overrides proxy in config.json)
PROXY_URL=http://user:pass@unblocker.iproyal.com:12323

# Twitter/X API (poster)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Reddit API (poster)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# NanoBanana 2 API (poster — optional, Pillow fallback if empty)
NANOBANANA_API_KEY=
