# Validator (IPRoyal proxy — set in config.json, not here)
# IPROYAL_PROXY_URL=http://user:pass@geo.iproyal.com:12321

# GitHub (orchestrator only — Plan C)
# GITHUB_TOKEN=ghp_xxxx

# Twitter/X (poster only — Plan C)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# Reddit (poster only — Plan C)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
